# ==============================
# إعدادات قاعدة البيانات القديمة (MySQL PHP)
# ==============================
OLD_DB_HOST=localhost
OLD_DB_PORT=3306
OLD_DB_NAME=hr_system
OLD_DB_USER=root
OLD_DB_PASSWORD=

# ==============================
# إعدادات قاعدة البيانات الجديدة (Django)
# ==============================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hr_django
DB_USER=root
DB_PASSWORD=

# ==============================
# إعدادات Django - مهم جداً للإنتاج!
# ==============================
# مفتاح سري فريد - استخدم: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-very-long-random-string-in-production
# للإنتاج يجب تغييره إلى False
DEBUG=True
# أضف دومينك هنا
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ==============================
# إعدادات اللغة
# ==============================
LANGUAGE_CODE=ar
TIME_ZONE=Asia/Riyadh

# ==============================
# إعدادات التخزين السحابي Cloudflare R2
# ==============================
USE_R2_STORAGE=False
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=hr-files
R2_PUBLIC_URL=https://your-bucket.your-domain.com
